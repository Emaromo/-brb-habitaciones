# Copiá este archivo como .env y completá los valores
# En EasyPanel, configurar estas variables directamente en el panel (NO subir .env a git)

# Base de datos
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=brb_habitaciones;Username=brb;Password=CAMBIAR

# JWT — generá un secret aleatorio de al menos 32 caracteres
Jwt__Secret=CAMBIAR_POR_STRING_ALEATORIO_LARGO_MINIMO_32_CARACTERES
Jwt__Issuer=https://api.brbhabitaciones.com.ar
Jwt__Audience=https://brbhabitaciones.com.ar
Jwt__AccessTokenMinutes=60
Jwt__RefreshTokenDays=30

# CORS
Cors__AllowedOrigins=https://brbhabitaciones.com.ar

# Cloudinary — obtené las credenciales en https://console.cloudinary.com
Cloudinary__CloudName=TU_CLOUD_NAME
Cloudinary__ApiKey=TU_API_KEY
Cloudinary__ApiSecret=TU_API_SECRET
